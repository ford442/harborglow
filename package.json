{
    "name": "harborglow",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build && npm run build:wasm",
        "build:analyze": "tsc && vite build --mode analyze",
        "build:wasm": "cd cpp && ./build.sh",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "test": "vitest run",
        "smoke:dev-transform": "node scripts/smoke-dev-transform.mjs",
        "test:dev-transform": "npm run smoke:dev-transform",
        "test:e2e": "playwright test",
        "test:e2e:update": "playwright test --update-snapshots",
        "test:e2e:install": "playwright install chromium --with-deps",
        "test:dev-transform": "node scripts/smoke-dev-transform.mjs",
        "generate:ship-glb": "node scripts/generate-ship-glb.mjs",
        "heartbeat": "echo '=== HEARTBEAT ===' && git status --porcelain && grep -r 'TODO\\|FIXME' src/ --include='*.ts' --include='*.tsx' || true && npm run build && npm test",
        "preview": "vite preview"
    },
    "dependencies": {
        "@react-three/drei": "^9.122.0",
        "@react-three/fiber": "^8.15.11",
        "@react-three/postprocessing": "^2.15.1",
        "@react-three/rapier": "^1.3.1",
        "@types/three": "^0.158.0",
        "leva": "^0.9.35",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "three": "^0.160.0",
        "three-stdlib": "^2.36.1",
        "tone": "^14.7.77",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "postcss": "^8.5.6",
        "rollup-plugin-visualizer": "^5.12.0",
        "tailwindcss": "^3.4.19",
        "terser": "^5.46.1",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^5.0.8",
        "vitest": "^4.1.5"
    }
}
